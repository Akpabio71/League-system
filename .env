# NexGen MVP Environment Configuration
# Copy this file to .env and populate values for your environment

# ============================================================================
# ENVIRONMENT IDENTIFICATION
# ============================================================================
NODE_ENV=development
ENVIRONMENT=local
APP_NAME=nexgen-esport-mvp
APP_VERSION=0.1.0

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=3000
HOST=localhost
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://nexgen_user:password@localhost:5432/nexgen_mvp_local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexgen_mvp_local
DB_USER=nexgen_user
DB_PASSWORD=change_me_in_production
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=5000
DB_IDLE_TIMEOUT=30000

# ============================================================================
# AUTHENTICATION & SESSIONS
# ============================================================================
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_ACCESS_TOKEN_EXPIRES_IN=900
JWT_REFRESH_TOKEN_EXPIRES_IN=2592000
SESSION_SECRET=your_session_secret_change_in_production
REFRESH_TOKEN_ROTATION_ENABLED=true

# ============================================================================
# SECURITY
# ============================================================================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
LOGIN_THROTTLE_WINDOW_SECONDS=900
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION_SECONDS=900

# ============================================================================
# EMAIL & NOTIFICATIONS
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=NexGen Esports
SMTP_FROM_EMAIL=noreply@nexgenesports.com

# Email templates
EMAIL_VERIFICATION_TEMPLATE_ID=template_id_here
PASSWORD_RESET_TEMPLATE_ID=template_id_here
MATCH_REMINDER_TEMPLATE_ID=template_id_here

# ============================================================================
# OBJECT STORAGE (AWS S3 or equivalent)
# ============================================================================
STORAGE_TYPE=s3
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=nexgen-mvp-uploads
S3_UPLOAD_EXPIRY_HOURS=24
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=image/jpeg,image/png,video/mp4,application/pdf

# ============================================================================
# REALTIME & NOTIFICATIONS
# ============================================================================
PUSHER_ENABLED=true
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=mt1
REALTIME_FALLBACK_POLLING_INTERVAL_MS=15000

# ============================================================================
# JOB SCHEDULING
# ============================================================================
JOB_QUEUE_ENABLED=true
JOB_QUEUE_TYPE=bull
REDIS_URL=redis://localhost:6379
CHECK_IN_OPEN_CRON=0 0 * * *
CHECK_IN_CLOSE_CRON=30 23 * * *
NO_SHOW_SCAN_CRON=0 1 * * *
STANDINGS_RECALC_CRON=0 2 * * *
SEASON_MAINTENANCE_CRON=0 3 * * *
JOB_QUEUE_CONCURRENCY=5
JOB_ATTEMPTS=3
JOB_BACKOFF_DELAY_MS=5000

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json
SENTRY_ENABLED=false
SENTRY_DSN=
DATADOG_ENABLED=false
DATADOG_API_KEY=
DATADOG_ENVIRONMENT=development

# Health check configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_MS=30000
DB_HEALTH_CHECK_TIMEOUT_MS=5000

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_CLUBS_ENABLED=true
FEATURE_DISPUTES_ENABLED=true
FEATURE_PENALTIES_ENABLED=true
FEATURE_CLUBS_ALLOW_CREATION=true
FEATURE_OPEN_REGISTRATION=true
FEATURE_AUTO_CONFIRM_RESULTS=false

# ============================================================================
# BACKUP & RECOVERY
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups
DATABASE_BACKUP_ENABLED=true
DATABASE_BACKUP_LOCATION=s3://nexgen-backups/database

# ============================================================================
# ADMIN & OPERATIONS
# ============================================================================
OPERATOR_SCOPE_RESTRICTION_ENABLED=true
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365
COMPLIANCE_MODE_ENABLED=false

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=mixpanel
ANALYTICS_TOKEN=

# ============================================================================
# DEBUG & DEVELOPMENT
# ============================================================================
DEBUG_MODE=false
VERBOSE_LOGGING=false
SEED_DATABASE_ON_BOOT=false
ALLOW_TEST_ENDPOINTS=false
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
